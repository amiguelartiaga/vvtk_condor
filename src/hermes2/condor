#!/bin/bash

#-------------------------------------------------------------------
# help / no-args guard
if [[ $# -eq 0 || "$1" == "--help" || "$1" == "-h" ]]; then
    cat <<'HELP'
Usage: condor [OPTIONS] EXECUTABLE [ARGS...]

Submit a job to HTCondor. Defaults: blocking and any node.

Options:
    --noblock   Return immediately instead of waiting for the job to finish
    --nolock    With --noblock, skip lock-file checks and creation
    --nodate    Use legacy log names without appending a timestamp
    --cpu       Disable GPU useful for scripting
    --nice      Run as nice user (lower priority)
    --autoenv   When EXECUTABLE is python and a venv/conda env is active,
                wrap the job in an auto-generated activate script
    --help      Show this help message

Examples:
    condor my_script.sh                        # blocking job
    condor --noblock my_script.sh arg1 arg2    # non-blocking job
    condor --nodate my_script.sh               # Reuse legacy non-dated log names
    condor --cpu my_script.sh                  # CPU-mode compatibility
    condor --nice my_script.sh                 # Nice job
    condor --cpu my_script.sh -x 5             # CPU-mode job with args
    condor --autoenv python hello.py           # Run python inside the active venv/conda env

Optional shell aliases (installer can add them to ~/.bashrc):
    condor_cpu        →  condor --cpu
  condor_nice       →  condor --nice
HELP
    exit 0
fi

#-------------------------------------------------------------------
# parse options: --noblock, --nolock, --nodate, --cpu, --nice, --autoenv
BLOCK_MODE="block"
NOLOCK=false
APPEND_DATE=true
NICE_MODE=false
AUTOENV=false

while [[ "$1" == --* ]]; do
    case "$1" in
        --noblock)
            BLOCK_MODE="noblock"
            shift
            ;;
        --nolock)
            NOLOCK=true
            shift
            ;;
        --nodate)
            APPEND_DATE=false
            shift
            ;;
        --cpu)
            shift
            ;;
        --nice)
            NICE_MODE=true
            shift
            ;;
        --autoenv)
            AUTOENV=true
            shift
            ;;
        *)
            break
            ;;
    esac
done

USE_LOCK=true
if [[ "$BLOCK_MODE" == "noblock" && "$NOLOCK" == true ]]; then
    USE_LOCK=false
fi

file=$1

#-------------------------------------------------------------------
# create dir
mkdir -p .condor/

#-------------------------------------------------------------------
# base filename
args="$*"
args=${args// /_} 
args=${args//-/_} 
args=${args//\//_} 
file_condor_base=$args
if [[ "$APPEND_DATE" == true ]]; then
    file_condor_base="${file_condor_base}_$(date +%Y%m%d_%H%M%S_%N)"
fi

#-------------------------------------------------------------------
# autoenv: when the executable is python and an active venv/conda env is
# detected, wrap the call in a generated activate script so the job runs
# inside that environment.
EXEC_PATH=$(command -v "$file" 2>/dev/null || readlink -f "$file")
if [[ "$AUTOENV" == true && "$(basename "$file")" == "python" ]]; then
    env_type=$(python - <<'PYEOF'
import sys, os
p = os.path.realpath(sys.executable)
if "/miniconda3/envs/" in p or "/anaconda3/envs/" in p:
    print("conda_named")
elif p.endswith("/miniconda3/bin/python") or p.endswith("/anaconda3/bin/python"):
    print("conda_base")
elif sys.prefix != getattr(sys, "base_prefix", sys.prefix):
    print("venv")
else:
    print("none")
PYEOF
)
    if [[ "$env_type" == "none" ]]; then
        echo "autoenv: no active virtual environment detected, running python directly"
    else
        py_path=$(which python)
        activate_path="$(dirname "$py_path")/activate"
        if [[ ! -f "$activate_path" ]]; then
            echo "autoenv: WARNING activate script not found at $activate_path, running python directly"
        else
            wrapper=".condor/${file_condor_base}_activate.sh"
            cat > "$wrapper" <<WRAP
#!/bin/bash
# Auto-generated by condor --autoenv
# Detected environment: $env_type
source "$activate_path"
exec python "\$@"
WRAP
            chmod +x "$wrapper"
            EXEC_PATH=$(readlink -f "$wrapper")
            echo "autoenv: detected $env_type, wrapper $wrapper -> $activate_path"
        fi
    fi
fi

#-------------------------------------------------------------------
# lock check: warn if a previous job with the same name is still running
lock_file=.condor/${file_condor_base}._lock
clog_file=.condor/${file_condor_base}._clog
if [[ "$USE_LOCK" == true && -f "$lock_file" ]]; then
    if [[ -f "$clog_file" ]] && grep -qE '^005|^009' "$clog_file"; then
        echo "Previous job finished. Removing stale lock."
        rm -f "$lock_file"
    else
        echo -e "\e[1;31mWARNING: A job with the same name is already running or queued!\e[0m"
        echo -e "\e[1;31mLock file: $lock_file\e[0m"
        echo -e "\e[1;33mIf the previous job is no longer running, remove the lock manually:\e[0m"
        echo -e "\e[1;33m  rm $lock_file\e[0m"
        exit 1
    fi
fi

#-------------------------------------------------------------------
# create condor config
condor_task=.condor/${file_condor_base}._sub

#-------------------------------------------------------------------
if [ -f condor.cfg ];
then
    echo "condor.cfg exists."
    cp condor.cfg ${condor_task} 
else
   echo "condor.cfg does not exist, creating default"

   # build nice_user line
   if [[ "$NICE_MODE" == true ]]; then
       NICE_LINE="nice_user             = True"
   else
       NICE_LINE="#nice_user             = True"
   fi

#::::::::::::::::::::::::::::::::::::::::::
cat > ${condor_task}  << EOF

universe              = vanilla
notification          = Never 
${NICE_LINE}
getenv                = True
+Architecture="GPU3090"
should_transfer_files = no

EOF
#::::::::::::::::::::::::::::::::::::::::::
fi

#-------------------------------------------------------------------

#::::::::::::::::::::::::::::::::::::::::::
cat >> ${condor_task} << EOF
executable = ${EXEC_PATH}
arguments  = ${@:2}
output     = .condor/${file_condor_base}.log
error      = .condor/${file_condor_base}.err
log        = .condor/${file_condor_base}._clog
queue

EOF
#::::::::::::::::::::::::::::::::::::::::::

#-------------------------------------------------------------------
# view the condor config

#cat ${condor_task}

#-------------------------------------------------------------------
# clean old condor log so condor_wait doesn't see stale events
rm -f .condor/${file_condor_base}._clog

#-------------------------------------------------------------------
# create lock file
if [[ "$USE_LOCK" == true ]]; then
    touch "$lock_file"
fi


#-------------------------------------------------------------------
# launch condor job

#-------------------------------------------------------------------
# log
echo "-----------------------------"    
echo "log output: .condor/${file_condor_base}.log"
echo "err output: .condor/${file_condor_base}.err"
echo "-----------------------------"

if [[ "$BLOCK_MODE" == "block" ]]; then
    # block until the job is done
    _condor_submit.sh --sync y --config ${condor_task}
else
    # non-blocking call
    _condor_submit.sh --config ${condor_task}
fi

if [[ "$BLOCK_MODE" == "block" ]]; then
    echo "-----------------------------"
    echo "Job completed. "
    log_file=.condor/${file_condor_base}.log
    if [[ -f "$log_file" ]]; then
        line_count=$(wc -l < "$log_file")
        if (( line_count > 100 )); then
            head -n 20 "$log_file"
            echo "..."
            tail -n 20 "$log_file"
        else
            cat "$log_file"
        fi
    else
        cat "$log_file"
    fi
    if [[ "$USE_LOCK" == true ]]; then
        rm -f "$lock_file"
    fi
fi

#-------------------------------------------------------------------
# clean
#rm -rf .condor/
