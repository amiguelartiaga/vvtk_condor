#!/bin/bash

#-------------------------------------------------------------------
# help / no-args guard
if [[ $# -eq 0 || "$1" == "--help" || "$1" == "-h" ]]; then
    cat <<'HELP'
Usage: condor [OPTIONS] EXECUTABLE [ARGS...]

Submit a job to HTCondor. Defaults: GPU enabled, 2000 MB, blocking and any node.

Options:
    --noblock   Return immediately instead of waiting for the job to finish
    --nolock    With --noblock, skip lock-file checks and creation
    --nodate    Use legacy log names without appending a timestamp
    --gpu N     Request N GPUs explicitly
    --cpu       Disable GPU (alias: --gpu 0) useful for scripting
    --memory N  Request N MB of memory explicitly
    --prio      High prority job (alias of --level 3)
    --nice      Run as nice user (alias of --level 0)
    --level N   Priority level (0..3):
                  0 = nice job (lowest priority, may be evicted)
                  1 = normal job (evicts level 0)
                  2 = +Prioridad = "Media" (evicts level 0/1)
                  3 = +Prioridad = "Alta"  (evicts level 0/1/2)
    --local     Pin the job to the current machine ($HOSTNAME)
    --autoenv   When EXECUTABLE is python and a venv/conda env is active,
                wrap the job in an auto-generated activate script
    --help      Show this help message

Examples:
    condor my_script.sh                        # GPU job, blocking 
    condor --gpu 2 my_script.sh                # Request 2 GPUs
    condor --noblock my_script.sh arg1 arg2    # GPU job, non-blocking
    condor --nodate my_script.sh               # Reuse legacy non-dated log names
    condor --cpu my_script.sh                  # CPU-only job, blocking
    condor --memory 2000 my_script.sh          # Explicitly request 2000 MB
    condor --prio my_script.sh                 # High-priority job (level 3)
    condor --level 0 my_script.sh              # Nice job   (lowest priority)
    condor --level 1 my_script.sh              # Normal job (no nice, no prio)
    condor --level 2 my_script.sh              # Media-priority job
    condor --level 3 my_script.sh              # Alta-priority job (same as --prio)
    condor --nice --local my_script.sh         # Nice GPU job pinned to this machine
    condor --cpu --local my_script.sh -x 5     # CPU job pinned locally with args
    condor --autoenv python hello.py           # Run python inside the active venv/conda env

Optional shell aliases (installer can add them to ~/.bashrc):
    condor_cpu        →  condor --cpu
    condor_nice       →  condor --nice
    condor_local      →  condor --local
    condor_cpu_local  →  condor --cpu --local
    condor_nice_local →  condor --nice --local
HELP
    exit 0
fi

#-------------------------------------------------------------------
# parse options: --noblock, --nolock, --nodate, --gpu, --cpu, --memory, --prio, --nice, --local, --autoenv
BLOCK_MODE="block"
NGPUS=1
NOLOCK=false
APPEND_DATE=true
NICE_MODE=false
LOCAL_MODE=false
PRIO_MODE=false
LEVEL=""
REQUEST_MEMORY=500
AUTOENV=false

while [[ "$1" == --* ]]; do
    case "$1" in
        --noblock)
            BLOCK_MODE="noblock"
            shift
            ;;
        --nolock)
            NOLOCK=true
            shift
            ;;
        --nodate)
            APPEND_DATE=false
            shift
            ;;
        --gpu)
            if [[ -z "$2" || "$2" == --* || ! "$2" =~ ^[0-9]+$ ]]; then
                echo "ERROR: --gpu requires a non-negative integer value"
                exit 1
            fi
            NGPUS="$2"
            shift
            shift
            ;;
        --cpu)
            NGPUS=0
            shift
            ;;
        --memory)
            if [[ -z "$2" || "$2" == --* ]]; then
                echo "ERROR: --memory requires a value in MB"
                exit 1
            fi
            REQUEST_MEMORY="$2"
            shift
            shift
            ;;
        --prio)
            PRIO_MODE=true
            shift
            ;;
        --nice)
            NICE_MODE=true
            shift
            ;;
        --level)
            if [[ -z "$2" || ! "$2" =~ ^[0-3]$ ]]; then
                echo "ERROR: --level requires an integer in 0..3"
                exit 1
            fi
            LEVEL="$2"
            shift
            shift
            ;;
        --local)
            LOCAL_MODE=true
            shift
            ;;
        --autoenv)
            AUTOENV=true
            shift
            ;;
        *)
            break
            ;;
    esac
done

USE_LOCK=true
if [[ "$BLOCK_MODE" == "noblock" && "$NOLOCK" == true ]]; then
    USE_LOCK=false
fi

# --level overrides --nice/--prio when provided
PRIO_TAG=""
if [[ "$PRIO_MODE" == true ]]; then
    PRIO_TAG="Alta"
fi
if [[ -n "$LEVEL" ]]; then
    NICE_MODE=false
    PRIO_TAG=""
    case "$LEVEL" in
        0) NICE_MODE=true ;;
        1) ;;
        2) PRIO_TAG="Media" ;;
        3) PRIO_TAG="Alta" ;;
    esac
fi

file=$1

#-------------------------------------------------------------------
# create dir
mkdir -p .condor/

#-------------------------------------------------------------------
# base filename
args="$*"
args=${args// /_} 
args=${args//-/_} 
args=${args//\//_} 
file_condor_base=$args
if [[ "$APPEND_DATE" == true ]]; then
    file_condor_base="${file_condor_base}_$(date +%Y%m%d_%H%M%S_%N)"
fi

#-------------------------------------------------------------------
# autoenv: when the executable is python and an active venv/conda env is
# detected, wrap the call in a generated activate script so the job runs
# inside that environment.
EXEC_PATH=$(command -v "$file" 2>/dev/null || readlink -f "$file")
if [[ "$AUTOENV" == true && "$(basename "$file")" == "python" ]]; then
    env_type=$(python - <<'PYEOF'
import sys, os
p = os.path.realpath(sys.executable)
if "/miniconda3/envs/" in p or "/anaconda3/envs/" in p:
    print("conda_named")
elif p.endswith("/miniconda3/bin/python") or p.endswith("/anaconda3/bin/python"):
    print("conda_base")
elif sys.prefix != getattr(sys, "base_prefix", sys.prefix):
    print("venv")
else:
    print("none")
PYEOF
)
    if [[ "$env_type" == "none" ]]; then
        echo "autoenv: no active virtual environment detected, running python directly"
    else
        py_path=$(which python)
        activate_path="$(dirname "$py_path")/activate"
        if [[ ! -f "$activate_path" ]]; then
            echo "autoenv: WARNING activate script not found at $activate_path, running python directly"
        else
            wrapper=".condor/${file_condor_base}_activate.sh"
            cat > "$wrapper" <<WRAP
#!/bin/bash
# Auto-generated by condor --autoenv
# Detected environment: $env_type
source "$activate_path"
exec python "\$@"
WRAP
            chmod +x "$wrapper"
            EXEC_PATH=$(readlink -f "$wrapper")
            echo "autoenv: detected $env_type, wrapper $wrapper -> $activate_path"
        fi
    fi
fi

#-------------------------------------------------------------------
# lock check: warn if a previous job with the same name is still running
lock_file=.condor/${file_condor_base}._lock
clog_file=.condor/${file_condor_base}._clog
if [[ "$USE_LOCK" == true && -f "$lock_file" ]]; then
    if [[ -f "$clog_file" ]] && grep -qE '^005|^009' "$clog_file"; then
        echo "Previous job finished. Removing stale lock."
        rm -f "$lock_file"
    else
        echo -e "\e[1;31mWARNING: A job with the same name is already running or queued!\e[0m"
        echo -e "\e[1;31mLock file: $lock_file\e[0m"
        echo -e "\e[1;33mIf the previous job is no longer running, remove the lock manually:\e[0m"
        echo -e "\e[1;33m  rm $lock_file\e[0m"
        exit 1
    fi
fi

#-------------------------------------------------------------------
# create condor config
condor_task=.condor/${file_condor_base}._sub

#-------------------------------------------------------------------
if [ -f condor.cfg ];
then
    echo "condor.cfg exists."
    cp condor.cfg ${condor_task}
    cat condor.cfg 
else
   echo "condor.cfg does not exist, creating default"

   # build nice_user line
   if [[ "$NICE_MODE" == true ]]; then
       NICE_LINE="nice_user             = True"
   else
       NICE_LINE="#nice_user             = True"
   fi

#::::::::::::::::::::::::::::::::::::::::::
cat > ${condor_task}  << EOF

universe              = vanilla
notification          = Never 
${NICE_LINE}
getenv                = True
request_cpus          = 1
request_gpus          = ${NGPUS}
request_memory        = ${REQUEST_MEMORY} 
should_transfer_files = no

EOF
#::::::::::::::::::::::::::::::::::::::::::
fi

#-------------------------------------------------------------------
# if --local, pin the job to the current machine
if [[ "$LOCAL_MODE" == true ]]; then
    echo "requirements   = TARGET.Machine == \"${HOSTNAME}\"" >> ${condor_task}
fi

if [[ -n "$PRIO_TAG" ]]; then
    echo "+Prioridad = \"${PRIO_TAG}\"" >> ${condor_task}
fi

#-------------------------------------------------------------------

#::::::::::::::::::::::::::::::::::::::::::
cat >> ${condor_task} << EOF
executable = ${EXEC_PATH}
arguments  = ${@:2}
output     = .condor/${file_condor_base}.log
error      = .condor/${file_condor_base}.err
log        = .condor/${file_condor_base}._clog
queue

EOF
#::::::::::::::::::::::::::::::::::::::::::

#-------------------------------------------------------------------
# view the condor config

#cat ${condor_task}

#-------------------------------------------------------------------
# clean old condor log so condor_wait doesn't see stale events
rm -f .condor/${file_condor_base}._clog

#-------------------------------------------------------------------
# create lock file
if [[ "$USE_LOCK" == true ]]; then
    touch "$lock_file"
fi


#-------------------------------------------------------------------
# launch condor job

#-------------------------------------------------------------------
# log
echo "-----------------------------"    
echo "log output: .condor/${file_condor_base}.log"
echo "err output: .condor/${file_condor_base}.err"
echo "-----------------------------"

if [[ "$BLOCK_MODE" == "block" ]]; then
    # block until the job is done
    _condor_submit.sh --sync y --config ${condor_task}
else
    # non-blocking call
    _condor_submit.sh --config ${condor_task}
fi

if [[ "$BLOCK_MODE" == "block" ]]; then
    echo "-----------------------------"
    echo "Job completed. "
    log_file=.condor/${file_condor_base}.log
    if [[ -f "$log_file" ]]; then
        line_count=$(wc -l < "$log_file")
        if (( line_count > 100 )); then
            head -n 20 "$log_file"
            echo "..."
            tail -n 20 "$log_file"
        else
            cat "$log_file"
        fi
    else
        cat "$log_file"
    fi
    if [[ "$USE_LOCK" == true ]]; then
        rm -f "$lock_file"
    fi
fi

