#!/bin/bash

#-------------------------------------------------------------------
# help / no-args guard
if [[ $# -eq 0 || "$1" == "--help" || "$1" == "-h" ]]; then
    cat <<'HELP'
Usage: condor [OPTIONS] EXECUTABLE [ARGS...]

Submit a job to HTCondor. Defaults: GPU enabled, 2000 MB, blocking and any node.

Options:
  --noblock   Return immediately instead of waiting for the job to finish
  --nogpu     Disable GPU and request only 500 MB memory (alias: --cpu) useful for scripting
    --memory N  Request N MB of memory explicitly
  --nice      Run as nice user (lower priority)
  --local     Pin the job to the current machine ($HOSTNAME)
  --help      Show this help message

Examples:
  condor my_script.sh                        # GPU job, blocking
  condor --noblock my_script.sh arg1 arg2    # GPU job, non-blocking
  condor --nogpu my_script.sh                # CPU-only job, blocking
    condor --memory 2000 my_script.sh          # Explicitly request 2000 MB
  condor --nice --local my_script.sh         # Nice GPU job pinned to this machine
  condor --nogpu --local my_script.sh -x 5   # CPU job pinned locally with args

One-liner wrappers:
  condor_cpu        →  condor --nogpu
  condor_nice       →  condor --nice
  condor_local      →  condor --local
  condor_cpu_local  →  condor --nogpu --local
  condor_nice_local →  condor --nice --local
HELP
    exit 0
fi

#-------------------------------------------------------------------
# parse options: --noblock, --nogpu, --memory, --nice, --local
BLOCK_MODE="block"
GPU_MODE=1
NICE_MODE=false
LOCAL_MODE=false
REQUEST_MEMORY=500

while [[ "$1" == --* ]]; do
    case "$1" in
        --noblock)
            BLOCK_MODE="noblock"
            shift
            ;;
        --nogpu|--cpu)
            GPU_MODE=0
            shift
            ;;
        --memory)
            if [[ -z "$2" || "$2" == --* ]]; then
                echo "ERROR: --memory requires a value in MB"
                exit 1
            fi
            REQUEST_MEMORY="$2"
            shift
            shift
            ;;
        --nice)
            NICE_MODE=true
            shift
            ;;
        --local)
            LOCAL_MODE=true
            shift
            ;;
        *)
            break
            ;;
    esac
done

file=$1

#-------------------------------------------------------------------
# create dir
mkdir -p .condor/

#-------------------------------------------------------------------
# base filename
args="$*"
args=${args// /_} 
args=${args//-/_} 
args=${args//\//_} 
file_condor_base=$args

#-------------------------------------------------------------------
# lock check: warn if a previous job with the same name is still running
lock_file=.condor/${file_condor_base}.lock
clog_file=.condor/${file_condor_base}.clog
if [[ -f "$lock_file" ]]; then
    if [[ -f "$clog_file" ]] && grep -qE '^005|^009' "$clog_file"; then
        echo "Previous job finished. Removing stale lock."
        rm -f "$lock_file"
    else
        echo -e "\e[1;31mWARNING: A job with the same name is already running or queued!\e[0m"
        echo -e "\e[1;31mLock file: $lock_file\e[0m"
        echo -e "\e[1;33mIf the previous job is no longer running, remove the lock manually:\e[0m"
        echo -e "\e[1;33m  rm $lock_file\e[0m"
        exit 1
    fi
fi

#-------------------------------------------------------------------
# create condor config
condor_task=.condor/${file_condor_base}.sub

#-------------------------------------------------------------------
if [ -f condor.cfg ];
then
    echo "condor.cfg exists."
    cp condor.cfg ${condor_task} 
else
   echo "condor.cfg does not exist, creating default"

   # build nice_user line
   if [[ "$NICE_MODE" == true ]]; then
       NICE_LINE="nice_user             = True"
   else
       NICE_LINE="#nice_user             = True"
   fi

#::::::::::::::::::::::::::::::::::::::::::
cat > ${condor_task}  << EOF

universe              = vanilla
notification          = Never 
${NICE_LINE}
getenv                = True
request_cpus          = 1
request_gpus          = ${GPU_MODE}
request_memory        = ${REQUEST_MEMORY} 
should_transfer_files = no

EOF
#::::::::::::::::::::::::::::::::::::::::::
fi

#-------------------------------------------------------------------
# if --local, pin the job to the current machine
if [[ "$LOCAL_MODE" == true ]]; then
    echo "requirements   = TARGET.Machine == \"${HOSTNAME}\"" >> ${condor_task}
fi

#-------------------------------------------------------------------

#::::::::::::::::::::::::::::::::::::::::::
cat >> ${condor_task} << EOF
executable = `which ${file}` 
arguments  = ${@:2}
output     = .condor/${file_condor_base}.log
error      = .condor/${file_condor_base}.err
log        = .condor/${file_condor_base}.clog
queue

EOF
#::::::::::::::::::::::::::::::::::::::::::

#-------------------------------------------------------------------
# view the condor config

#cat ${condor_task}

#-------------------------------------------------------------------
# clean old condor log so condor_wait doesn't see stale events
rm -f .condor/${file_condor_base}.clog

#-------------------------------------------------------------------
# create lock file
touch "$lock_file"


#-------------------------------------------------------------------
# launch condor job

if [[ "$BLOCK_MODE" == "block" ]]; then
    # block until the job is done
    _condor_submit.sh --sync y --config ${condor_task}
else
    # non-blocking call
    _condor_submit.sh --config ${condor_task}
fi

#-------------------------------------------------------------------
# log
echo "-----------------------------"    
echo "log output: .condor/${file_condor_base}.log"
echo "err output: .condor/${file_condor_base}.err"
echo "-----------------------------"

if [[ "$BLOCK_MODE" == "block" ]]; then
    echo "-----------------------------"
    echo "Job completed. "
    cat .condor/${file_condor_base}.log
    rm -f "$lock_file"
fi

#-------------------------------------------------------------------
# clean
#rm -rf .condor/
