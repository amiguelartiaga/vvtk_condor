#!/bin/bash

#-------------------------------------------------------------------
# help / no-args guard
if [[ $# -eq 0 || "$1" == "--help" || "$1" == "-h" ]]; then
    cat <<'HELP'
Usage: condor_for [OPTIONS] EXECUTABLE [ARGS...] N_JOBS

Submit N_JOBS indexed jobs to HTCondor. Each job receives its index (0..N-1)
as the last argument. Defaults: GPU enabled, 2000 MB, blocking and any node.

Options:
    --noblock    Return immediately instead of waiting for jobs to finish
    --nolock     With --noblock, skip lock-file checks and creation
    --cpu        Disable GPU and request only 500 MB memory
    --memory N   Request N MB of memory explicitly
    --prio       Add +Prioridad = "Alta" to the submit config
    --nice       Run as nice user (lower priority)
    --local      Pin jobs to the current machine ($HOSTNAME)
    --help       Show this help message

Examples:
    condor_for my_script.sh 10                        # 10 GPU jobs, blocking
    condor_for --noblock my_script.sh --arg1 10       # 10 GPU jobs, non-blocking
    condor_for --cpu my_script.sh 20                  # 20 CPU-only jobs
    condor_for --nice --local my_script.sh 5          # 5 nice GPU jobs, local
    condor_for --memory 4000 my_script.sh 10          # 10 jobs with 4 GB
    condor_for --prio my_script.sh 10                 # 10 high-priority jobs
HELP
    exit 0
fi

#-------------------------------------------------------------------
# parse options: --noblock, --nolock, --cpu, --memory, --prio, --nice, --local
BLOCK_MODE="block"
GPU_MODE=1
NOLOCK=false
NICE_MODE=false
LOCAL_MODE=false
PRIO_MODE=false
REQUEST_MEMORY=500

while [[ "$1" == --* ]]; do
    case "$1" in
        --noblock)
            BLOCK_MODE="noblock"
            shift
            ;;
        --nolock)
            NOLOCK=true
            shift
            ;;
        --cpu)
            GPU_MODE=0
            REQUEST_MEMORY=500
            shift
            ;;
        --memory)
            if [[ -z "$2" || "$2" == --* ]]; then
                echo "ERROR: --memory requires a value in MB"
                exit 1
            fi
            REQUEST_MEMORY="$2"
            shift
            shift
            ;;
        --prio)
            PRIO_MODE=true
            shift
            ;;
        --nice)
            NICE_MODE=true
            shift
            ;;
        --local)
            LOCAL_MODE=true
            shift
            ;;
        *)
            break
            ;;
    esac
done

USE_LOCK=true
if [[ "$BLOCK_MODE" == "noblock" && "$NOLOCK" == true ]]; then
    USE_LOCK=false
fi

file=$1
n_jobs=${@: -1}

#-------------------------------------------------------------------
# create dir
mkdir -p .condor/

#-------------------------------------------------------------------
# base filename
args="$*"
args=${args// /_} 
args=${args//-/_} 
args=${args//\//_} 

file_condor_base=$args

#-------------------------------------------------------------------
# lock check: warn if a previous job with the same name is still running
lock_file=.condor/${file_condor_base}.lock
clog_file=.condor/${file_condor_base}.clog
if [[ "$USE_LOCK" == true && -f "$lock_file" ]]; then
    if [[ -f "$clog_file" ]] && grep -qE '^005|^009' "$clog_file"; then
        echo "Previous job finished. Removing stale lock."
        rm -f "$lock_file"
    else
        echo -e "\e[1;31mWARNING: A job with the same name is already running or queued!\e[0m"
        echo -e "\e[1;31mLock file: $lock_file\e[0m"
        echo -e "\e[1;33mIf the previous job is no longer running, remove the lock manually:\e[0m"
        echo -e "\e[1;33m  rm $lock_file\e[0m"
        exit 1
    fi
fi

#-------------------------------------------------------------------
# create condor config
condor_task=.condor/${file_condor_base}.sub

#-------------------------------------------------------------------
if [ -f condor.cfg ];
then
    echo "condor.cfg exists."
    cp condor.cfg ${condor_task} 
else
   echo "condor.cfg does not exist, creating default"

   # build nice_user line
   if [[ "$NICE_MODE" == true ]]; then
       NICE_LINE="nice_user             = True"
   else
       NICE_LINE="#nice_user             = True"
   fi

#::::::::::::::::::::::::::::::::::::::::::
cat > ${condor_task}  << EOF

universe              = vanilla
notification          = Never 
${NICE_LINE}
getenv                = True
request_cpus          = 1
request_gpus          = ${GPU_MODE}
request_memory        = ${REQUEST_MEMORY} 
should_transfer_files = no

EOF
#::::::::::::::::::::::::::::::::::::::::::
fi

#-------------------------------------------------------------------
# if --local, pin jobs to the current machine
if [[ "$LOCAL_MODE" == true ]]; then
    echo "requirements   = TARGET.Machine == \"${HOSTNAME}\"" >> ${condor_task}
fi

if [[ "$PRIO_MODE" == true ]]; then
    echo '+Prioridad = "Alta"' >> ${condor_task}
fi

#-------------------------------------------------------------------
# append executable, arguments and per-job queue entries

#::::::::::::::::::::::::::::::::::::::::::
cat >> ${condor_task} << EOF
executable = `which ${file}`
arguments  = ${@:2:${#}-2} \$(icluster)
output     = .condor/${file_condor_base}_\$(ifile).log
error      = .condor/${file_condor_base}_\$(ifile).err
log        = .condor/${file_condor_base}.clog

EOF
#::::::::::::::::::::::::::::::::::::::::::

for((i=0;i<$n_jobs;i++)); do
  ifile=`echo $i | awk '{ printf("%03d",$1);}'`
      echo "
      ifile = $ifile
      icluster = $i
      queue " 
done >> ${condor_task}

#-------------------------------------------------------------------
# view the condor config

#cat ${condor_task}

#-------------------------------------------------------------------
# clean old condor log so condor_wait doesn't see stale events
rm -f .condor/${file_condor_base}.clog

#-------------------------------------------------------------------
# create lock file
if [[ "$USE_LOCK" == true ]]; then
    touch "$lock_file"
fi

#-------------------------------------------------------------------
# launch condor job

if [[ "$BLOCK_MODE" == "block" ]]; then
    _condor_submit.sh --sync y --config ${condor_task}
    if [[ "$USE_LOCK" == true ]]; then
        rm -f "$lock_file"
    fi
else
    _condor_submit.sh --config ${condor_task}
fi

#-------------------------------------------------------------------
# log
echo "-----------------------------"    
echo "log output: .condor/${file_condor_base}_[0-$(printf "%03d" $((n_jobs-1)))].log"
echo "err output: .condor/${file_condor_base}_[0-$(printf "%03d" $((n_jobs-1)))].err"
echo "-----------------------------"
