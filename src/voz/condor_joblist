#!/bin/bash

if [[ "$1" == "--help" || "$1" == "-h" ]]; then
    cat <<'HELP'
Usage: condor_joblist [--color 0|1]

Show HTCondor jobs grouped by host.

Options:
  --color N   Highlight the current user's jobs in red when N=1 (default: 0)
  --help      Show this help message
HELP
    exit 0
fi

COLOR_MODE=0

while [[ "$1" == --* ]]; do
    case "$1" in
        --color)
            if [[ -z "$2" || ! "$2" =~ ^[01]$ ]]; then
                echo "ERROR: --color requires 0 or 1"
                exit 1
            fi
            COLOR_MODE="$2"
            shift
            shift
            ;;
        *)
            echo "ERROR: Unknown option: $1"
            exit 1
            ;;
    esac
done

COMMAND='condor_q -nobatch -g -allusers -af:j User JobStatus Iwd RemoteHost'

eval "${COMMAND}"                    | \
    sed 's:slot.*\@::g'              | \
    sed 's:@intra.unizar.es::g'       | \
    sed 's:@unizar.es::g'             | \
    sed 's:.intra.unizar.es::g'       | \
    sed 's:.unizar.es::g'             | \
    sed "s/[[:space:]]\+/ /g"        | \
    sed 's:undefined:  -  :g'         | \
    sed 's: 2 : R :g'                 | \
    sed 's: 1 : I :g'                 | \
    sed 's: 5 : H :g'                 | \
    sort -k 5 | JOBLIST_COLOR="${COLOR_MODE}" python <(
#::::::::::::::::::::::::::::::::::::::::::
cat << END
import os
import sys
from collections import OrderedDict, defaultdict

COLOR = "\033[0;31m"
RESET = "\033[0m"
CURRENT_USER = os.environ.get("USER") or os.environ.get("LOGNAME") or ""
COLOR_ENABLED = os.environ.get("JOBLIST_COLOR", "0") == "1"

d = defaultdict(list)


def format_line(line_):
    return "%7s  %-10s%19s%4s %-80s" % (
        line_[4],
        line_[0],
        line_[1],
        line_[2],
        line_[3],
    )


def print_line(line_):
    text = format_line(line_)
    owner = line_[1]
    normalized_owner = owner.split("@", 1)[0].split(".")[-1]
    if COLOR_ENABLED and (owner == CURRENT_USER or normalized_owner == CURRENT_USER):
        print(f"{COLOR}{text}{RESET}")
    else:
        print(text)


for raw_line in sys.stdin:
    line_ = raw_line.split()
    if len(line_) < 5:
        continue
    host = line_[-1]
    d[host].append(line_)

d = OrderedDict(sorted(d.items()))

print_line(["ID", "OWNER", "ST", "PATH", "HOST"])

for host in d:
    print('-' * 73)
    for line_ in d[host]:
        print_line(line_)

END
#::::::::::::::::::::::::::::::::::::::::::
)
 

