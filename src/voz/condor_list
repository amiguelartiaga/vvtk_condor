#!/bin/bash

#-------------------------------------------------------------------
# help / no-args guard
if [[ $# -eq 0 || "$1" == "--help" || "$1" == "-h" ]]; then
    cat <<'HELP'
Usage: condor_list [OPTIONS] EXECUTABLE [ARGS...] LIST_FILE

Submit one job per line in LIST_FILE. Each job receives its line as the last
argument. Defaults: GPU enabled, 2000 MB, blocking and any node.

Options:
    --noblock    Return immediately instead of waiting for jobs to finish
    --nolock     With --noblock, skip lock-file checks and creation
    --nodate     Use legacy log names without appending a timestamp
    --cpu        Disable GPU and request only 500 MB memory
    --memory N   Request N MB of memory explicitly
    --prio       Add +Prioridad = "Alta" to the submit config (alias of --level 3)
    --nice       Run as nice user (alias of --level 0)
    --level N    Priority level (0..3):
                   0 = nice jobs   (lowest priority, may be evicted)
                   1 = normal jobs (no nice, no prio)
                   2 = +Prioridad = "Media" (evicts level 0/1)
                   3 = +Prioridad = "Alta"  (evicts level 0/1/2)
    --local      Pin jobs to the current machine ($HOSTNAME)
    --help       Show this help message

Examples:
    condor_list my_script.sh items.txt                    # GPU jobs, blocking
    condor_list --noblock my_script.sh items.txt          # GPU jobs, non-blocking
    condor_list --nodate my_script.sh items.txt           # Reuse legacy non-dated log names
    condor_list --cpu my_script.sh items.txt              # CPU-only jobs
    condor_list --nice --local my_script.sh items.txt     # Nice GPU jobs, local
    condor_list --memory 4000 my_script.sh items.txt      # Jobs with 4 GB
    condor_list --prio my_script.sh items.txt             # High-priority jobs (level 3)
    condor_list --level 0 my_script.sh items.txt          # Nice jobs   (lowest priority)
    condor_list --level 1 my_script.sh items.txt          # Normal jobs (no nice, no prio)
    condor_list --level 2 my_script.sh items.txt          # Media-priority jobs
    condor_list --level 3 my_script.sh items.txt          # Alta-priority jobs (same as --prio)
HELP
    exit 0
fi

#-------------------------------------------------------------------
# parse options: --noblock, --nolock, --nodate, --cpu, --memory, --prio, --nice, --local
BLOCK_MODE="block"
GPU_MODE=1
NOLOCK=false
APPEND_DATE=true
NICE_MODE=false
LOCAL_MODE=false
PRIO_MODE=false
LEVEL=""
REQUEST_MEMORY=500

while [[ "$1" == --* ]]; do
    case "$1" in
        --noblock)
            BLOCK_MODE="noblock"
            shift
            ;;
        --nolock)
            NOLOCK=true
            shift
            ;;
        --nodate)
            APPEND_DATE=false
            shift
            ;;
        --cpu)
            GPU_MODE=0
            REQUEST_MEMORY=500
            shift
            ;;
        --memory)
            if [[ -z "$2" || "$2" == --* ]]; then
                echo "ERROR: --memory requires a value in MB"
                exit 1
            fi
            REQUEST_MEMORY="$2"
            shift
            shift
            ;;
        --prio)
            PRIO_MODE=true
            shift
            ;;
        --nice)
            NICE_MODE=true
            shift
            ;;
        --level)
            if [[ -z "$2" || ! "$2" =~ ^[0-3]$ ]]; then
                echo "ERROR: --level requires an integer in 0..3"
                exit 1
            fi
            LEVEL="$2"
            shift
            shift
            ;;
        --local)
            LOCAL_MODE=true
            shift
            ;;
        *)
            break
            ;;
    esac
done

USE_LOCK=true
if [[ "$BLOCK_MODE" == "noblock" && "$NOLOCK" == true ]]; then
    USE_LOCK=false
fi

# --level overrides --nice/--prio when provided
PRIO_TAG=""
if [[ "$PRIO_MODE" == true ]]; then
    PRIO_TAG="Alta"
fi
if [[ -n "$LEVEL" ]]; then
    NICE_MODE=false
    PRIO_TAG=""
    case "$LEVEL" in
        0) NICE_MODE=true ;;
        1) ;;
        2) PRIO_TAG="Media" ;;
        3) PRIO_TAG="Alta" ;;
    esac
fi

file=$1
list=${@: -1}
n_jobs=`wc -l ${list} | awk '{ print $1 }'`

#-------------------------------------------------------------------
# create dir
mkdir -p .condor/

#-------------------------------------------------------------------
# base filename
args="$*"
args=${args// /_} 
args=${args//-/_} 
args=${args//\//_} 

file_condor_base=$args
if [[ "$APPEND_DATE" == true ]]; then
    file_condor_base="${file_condor_base}_$(date +%Y%m%d_%H%M%S_%N)"
fi

#-------------------------------------------------------------------
# lock check: warn if a previous job with the same name is still running
lock_file=.condor/${file_condor_base}._lock
clog_file=.condor/${file_condor_base}._clog
if [[ "$USE_LOCK" == true && -f "$lock_file" ]]; then
    if [[ -f "$clog_file" ]] && grep -qE '^005|^009' "$clog_file"; then
        echo "Previous job finished. Removing stale lock."
        rm -f "$lock_file"
    else
        echo -e "\e[1;31mWARNING: A job with the same name is already running or queued!\e[0m"
        echo -e "\e[1;31mLock file: $lock_file\e[0m"
        echo -e "\e[1;33mIf the previous job is no longer running, remove the lock manually:\e[0m"
        echo -e "\e[1;33m  rm $lock_file\e[0m"
        exit 1
    fi
fi

#-------------------------------------------------------------------
# create condor config
condor_task=.condor/${file_condor_base}._sub

#-------------------------------------------------------------------
if [ -f condor.cfg ];
then
    echo "condor.cfg exists."
    cp condor.cfg ${condor_task} 
else
   echo "condor.cfg does not exist, creating default"

   # build nice_user line
   if [[ "$NICE_MODE" == true ]]; then
       NICE_LINE="nice_user             = True"
   else
       NICE_LINE="#nice_user             = True"
   fi

#::::::::::::::::::::::::::::::::::::::::::
cat > ${condor_task}  << EOF

universe              = vanilla
notification          = Never 
${NICE_LINE}
getenv                = True
request_cpus          = 1
request_gpus          = ${GPU_MODE}
request_memory        = ${REQUEST_MEMORY} 
should_transfer_files = no

EOF
#::::::::::::::::::::::::::::::::::::::::::
fi

#-------------------------------------------------------------------
# if --local, pin jobs to the current machine
if [[ "$LOCAL_MODE" == true ]]; then
    echo "requirements   = TARGET.Machine == \"${HOSTNAME}\"" >> ${condor_task}
fi

if [[ -n "$PRIO_TAG" ]]; then
    echo "+Prioridad = \"${PRIO_TAG}\"" >> ${condor_task}
fi

#-------------------------------------------------------------------
# append executable, arguments and per-job queue entries

#::::::::::::::::::::::::::::::::::::::::::
cat >> ${condor_task} << EOF
executable = `which ${file}`
arguments  = ${@:2:${#}-2} \$(iline)
output     = .condor/${file_condor_base}_\$(ifile).log
error      = .condor/${file_condor_base}_\$(ifile).err
log        = .condor/${file_condor_base}._clog

EOF
#::::::::::::::::::::::::::::::::::::::::::

for((i=0;i<$n_jobs;i++)); do
  ifile=`echo $i | awk '{ printf("%03d",$1);}'`
      echo "
      iline = `sed "$(( i + 1 ))q;d" $list`
      ifile = $ifile
      queue " 
done >> ${condor_task}

#-------------------------------------------------------------------
# view the condor config

#cat ${condor_task}

#-------------------------------------------------------------------
# clean old condor log so condor_wait doesn't see stale events
rm -f .condor/${file_condor_base}._clog

#-------------------------------------------------------------------
# create lock file
if [[ "$USE_LOCK" == true ]]; then
    touch "$lock_file"
fi

#-------------------------------------------------------------------
# launch condor job

if [[ "$BLOCK_MODE" == "block" ]]; then
    _condor_submit.sh --sync y --config ${condor_task}
    if [[ "$USE_LOCK" == true ]]; then
        rm -f "$lock_file"
    fi
else
    _condor_submit.sh --config ${condor_task}
fi
